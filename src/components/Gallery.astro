---
const items = [
  { video: "/images/ours/trabajos/grabacion-costa.mp4", poster: "/images/ours/trabajos/grabacion-costa-poster.jpg", title: "Grabación de costa", category: "Filmación" },
  { image: "/images/ours/trabajos/vista-aerea-urbana.webp", title: "Vista aérea urbana", category: "Fotografía" },
  { image: "/images/ours/trabajos/proyecto-inmobiliario.webp", title: "Proyecto inmobiliario", category: "Inmobiliaria" },
];
---

<section id="galeria" class="gallery">
  <div class="container">
    <div class="section-head">
      <h2 class="h-bold">Nuestros trabajos</h2>
      <p class="h-light">Imágenes que hablan por sí solas</p>
    </div>

    <div class="gallery-grid">
      {items.map((item) => (
        <div class="gallery-card">
          {item.video ? (
            <video class="gallery-video" data-src={item.video} poster={item.poster} loop muted playsinline preload="none" aria-label={item.title}></video>
          ) : (
            <picture>
              <source srcset={item.image.replace(/\.(jpe?g|png)$/, ".webp")} type="image/webp" />
              <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
            </picture>
          )}
          <div class="gallery-overlay">
            <span class="gallery-cat">{item.category}</span>
            <p class="gallery-title">{item.title}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery { background: #ffffff; padding: 100px 0; }
  .gallery .container { padding: 0 24px; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .gallery-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1), transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-card:hover { box-shadow: var(--shadow-md); transform: translateY(-4px); }
  .gallery-card img,
  .gallery-card video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(var(--colorNavyRGB), 0.85) 0%, rgba(var(--colorNavyRGB), 0) 55%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 26px 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .gallery-card:hover .gallery-overlay { opacity: 1; }
  .gallery-cat {
    background: var(--colorMain);
    color: #fff;
    padding: 4px 12px;
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 600;
    align-self: flex-start;
    margin-bottom: 10px;
    border-radius: 3px;
  }
  .gallery-title { color: #fff; font-size: 1.1rem; font-weight: 700; margin: 0; line-height: 1.3; }

  @media (max-width: 1024px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Carga y reproduce los vídeos de la galería solo cuando entran en el viewport.
  // Evita descargar el clip (y saturar la red) en la carga inicial.
  const vids = document.querySelectorAll<HTMLVideoElement>("video.gallery-video[data-src]");
  if (vids.length) {
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const v = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              if (!v.src && v.dataset.src) v.src = v.dataset.src;
              v.play().catch(() => {});
            } else {
              v.pause();
            }
          });
        },
        { rootMargin: "200px 0px" }
      );
      vids.forEach((v) => io.observe(v));
    } else {
      vids.forEach((v) => {
        if (v.dataset.src) {
          v.src = v.dataset.src;
          v.play().catch(() => {});
        }
      });
    }
  }
</script>
