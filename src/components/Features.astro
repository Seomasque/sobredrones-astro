---
const features = [
  {
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
    title: "Certificados por AESA",
    desc: "Operadora verificada y al día con la normativa española de drones. Volamos legal y seguro.",
  },
  {
    icon: '<path d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 0 1-3 0 2.704 2.704 0 0 0-3 0 2.704 2.704 0 0 1-3 0 2.704 2.704 0 0 0-3 0 2.701 2.701 0 0 1-1.5-.454M9 6l3 3m0 0 3-3m-3 3V3"/><rect x="2" y="2" width="20" height="20" rx="2"/>',
    title: "Cobertura ante pérdida del material",
    desc: "Copia y archivo de seguridad de todos los trabajos realizados, de por vida.",
  },
  {
    icon: '<path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    title: "Toda la Costa del Sol",
    desc: "Damos servicio en Marbella, Málaga capital y todos los municipios de la costa.",
  },
  {
    icon: '<path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>',
    title: "Vídeo y foto en 4K",
    desc: "Material en alta resolución listo para redes, inmobiliarias y campañas, con entrega ágil.",
  },
];
---

<section id="por-que-elegirnos" class="why">
  <div class="why-inner">
    <div class="why-intro">
      <p class="why-eyebrow">¿Por qué elegirnos?</p>
      <h2 class="why-title">Profesionalidad, seguridad y oferta más completa del mercado</h2>
      <p class="why-lead">
        Una operadora certificada por AESA, servicio audiovisual completo y gestión de permisos.
        Todo en un solo equipo, con la tranquilidad de saber que estás en buenas manos.
      </p>
      <a
        href="https://wa.me/34635247914"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-whatsapp"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
        Escríbenos por WhatsApp
      </a>

      <div class="why-gob">
        <p class="why-gob-label">Homologado por</p>
        <div class="why-gob-logos">
          <div class="why-gob-card">
            <img src="/images/gob/logo-ministerio-fomento.png" alt="Ministerio de Fomento" />
          </div>
          <div class="why-gob-card">
            <img src="/images/gob/logo-aesa.png" alt="AESA – Agencia Estatal de Seguridad Aérea" />
          </div>
          <div class="why-gob-card">
            <img src="/images/gob/enaire-color.svg" alt="ENAIRE" />
          </div>
        </div>
      </div>
    </div>

    <ul class="why-list">
      {features.map((f, i) => (
        <li class="why-item">
          <span class="why-index">0{i + 1}</span>
          <span class="why-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </span>
          <div class="why-body">
            <h3 class="why-name">{f.title}</h3>
            <p class="why-desc">{f.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .why { background-color: var(--colorGrey); padding: 100px 0; }
  .why-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 64px;
    align-items: start;
  }
  .why-eyebrow {
    color: var(--colorMainDark);
    font-size: 14px; text-transform: uppercase; letter-spacing: 0.18em;
    font-weight: 600; margin: 0 0 14px 0;
  }
  .why-title {
    font-size: 2.1rem; color: var(--colorDark); font-weight: 700;
    line-height: 1.2; margin: 0 0 18px 0;
  }
  .why-lead { font-size: 16px; color: var(--colorFont); margin: 0 0 28px 0; font-weight: 300; max-width: 38ch; }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: #25d366;
    color: #ffffff;
    border: none;
    padding: 13px 28px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 15px;
    transition: background-color 0.2s;
    text-decoration: none;
  }
  .btn-whatsapp:hover { background-color: #1ebe5d; color: #ffffff; }

  /* Logos gob */
  .why-gob { margin-top: 36px; }
  .why-gob-label {
    font-size: 11px;
    color: var(--colorFont);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
    margin: 0 0 12px 0;
    opacity: 0.7;
  }
  .why-gob-logos {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .why-gob-card {
    background: #ffffff;
    border-radius: 6px;
    padding: 8px 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--colorBorder);
  }
  .why-gob-card img {
    height: 36px;
    width: auto;
    object-fit: contain;
  }

  .why-list { list-style: none; margin: 0; padding: 0; }
  .why-item {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: start;
    gap: 22px;
    padding: 26px 0;
    border-top: 1px solid var(--colorBorder);
  }
  .why-item:last-child { border-bottom: 1px solid var(--colorBorder); }
  .why-index {
    font-size: 0.95rem; font-weight: 700; color: var(--colorSky);
    font-variant-numeric: tabular-nums; padding-top: 4px;
  }
  .why-icon { color: var(--colorMain); display: flex; padding-top: 2px; }
  .why-name { font-size: 1.15rem; font-weight: 700; color: var(--colorDark); margin: 0 0 6px 0; }
  .why-desc { font-size: 14px; color: var(--colorFont); line-height: 1.7; margin: 0; font-weight: 300; }

  @media (max-width: 900px) {
    .why-inner { grid-template-columns: 1fr; gap: 36px; }
    .why-title { font-size: 1.8rem; }
  }
  @media (max-width: 480px) {
    .why-item { grid-template-columns: auto 1fr; }
    .why-index { display: none; }
  }
</style>
