---
const items = [
  {
    icon: '<path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    label: "Zona de servicio",
    lines: ["Málaga, Marbella", "y toda la Costa del Sol"],
  },
  {
    icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>',
    label: "Teléfono",
    lines: ["+34 635 247 914"],
    href: "tel:+34635247914",
  },
  {
    icon: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
    label: "Email",
    lines: ["info@sobredrones.es"],
    href: "mailto:info@sobredrones.es",
  },
];
---

<section class="contact-bar">
  <div class="contact-bar-inner">
    <div class="contact-items">
      {items.map((item) => (
        <div class="contact-item">
          <span class="contact-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#457b9d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
          </span>
          <div>
            <p class="contact-label">{item.label}</p>
            {item.lines.map((line) => (
              item.href
                ? <p class="contact-line"><a href={item.href}>{line}</a></p>
                : <p class="contact-line">{line}</p>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="aesa-badge">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#7ef7f5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
      <span>Operadora verificada por AESA</span>
    </div>
  </div>
</section>

<style>
  .contact-bar { background-color: var(--colorNavy); padding: 36px 0; }
  .contact-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .contact-items {
    display: flex;
    flex: 1 1 600px;
    gap: 32px;
    flex-wrap: wrap;
  }
  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    flex: 1 1 180px;
    min-width: 180px;
  }
  .contact-icon {
    width: 50px; height: 50px; min-width: 50px;
    border-radius: 50%;
    background-color: rgba(var(--colorMainRGB), 0.18);
    border: 1px solid rgba(168, 218, 220, 0.35);
    display: flex; align-items: center; justify-content: center;
    transition: background-color 0.25s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .contact-item:hover .contact-icon {
    background-color: rgba(var(--colorMainRGB), 0.32);
    transform: scale(1.08);
  }
  .contact-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 4px 0;
    font-weight: 400;
  }
  .contact-line {
    font-size: 15px;
    color: #ffffff;
    font-weight: 500;
    margin: 0;
    line-height: 1.5;
  }
  .contact-line a { color: #ffffff; }
  .contact-line a:hover { color: var(--colorSky); }
  .aesa-badge {
    flex: 0 0 auto;
    display: flex; align-items: center; gap: 12px;
    color: #ffffff;
    font-weight: 600;
    font-size: 0.95rem;
    max-width: 220px;
    line-height: 1.3;
  }
  @media (max-width: 768px) {
    .aesa-badge { max-width: none; }
  }
</style>
