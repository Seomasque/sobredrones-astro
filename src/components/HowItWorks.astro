---
const steps = [
  {
    number: "01",
    image: "/images/ours/como-trabajamos/paso-01.webp",
    title: "Planificamos el vuelo",
    description: "Estudiamos tu proyecto, la localización y los permisos necesarios para conseguir las mejores tomas con total seguridad.",
  },
  {
    number: "02",
    image: "/images/ours/como-trabajamos/paso-02.webp",
    title: "Grabamos desde el aire",
    description: "Nuestros pilotos certificados realizan la sesión de vídeo y fotografía aérea en 4K en el día acordado.",
  },
  {
    number: "03",
    image: "/images/ours/como-trabajamos/paso-03.webp",
    title: "Entregamos tu material",
    description: "Editamos y te entregamos el contenido final listo para usar en redes sociales, portales o campañas.",
  },
];
---

<section id="como-trabajamos" class="hiw">
  <div class="container">
    <div class="section-head on-dark">
      <h2 class="h-bold">Cómo trabajamos</h2>
      <p class="h-light">Sencillo, seguro y profesional</p>
    </div>

    <div class="hiw-grid">
      {steps.map((step, index) => (
        <div class="hiw-step-wrapper">
          <div class="hiw-step">
            <div class="hiw-img">
              <picture>
                <source srcset={step.image.replace(/\.(jpe?g|png)$/, ".webp")} type="image/webp" />
                <img src={step.image} alt={step.title} width="400" height="280" loading="lazy" decoding="async" />
              </picture>
            </div>
            <p class="hiw-number">{step.number}</p>
            <h3 class="hiw-title">{step.title}</h3>
            <p class="hiw-desc">{step.description}</p>
          </div>
          {index < steps.length - 1 && <div class="hiw-divider"></div>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw { background: var(--colorNavy); padding: 56px 0; }
  .hiw .container { padding: 0 24px; }
  .hiw-grid { display: flex; flex-direction: row; gap: 0; }
  .hiw-step-wrapper { display: flex; flex-direction: row; flex: 1; }
  .hiw-step { flex: 1; padding: 0 32px; }
  .hiw-step-wrapper:first-child .hiw-step { padding-left: 0; }
  .hiw-step-wrapper:last-child .hiw-step { padding-right: 0; }
  .hiw-img { width: 100%; margin-bottom: 24px; }
  .hiw-img img { width: 100%; height: auto; border-radius: 6px; }
  .hiw-number { font-size: 3rem; font-weight: 800; color: var(--colorSky); margin: 0 0 8px 0; line-height: 1; }
  .hiw-title { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0 0 12px 0; }
  .hiw-desc { font-size: 14px; color: rgba(255, 255, 255, 0.7); line-height: 1.8; margin: 0; }
  .hiw-divider { width: 1px; background: rgba(168, 218, 220, 0.18); flex-shrink: 0; align-self: stretch; }

  @media (max-width: 768px) {
    .hiw-grid { flex-direction: column; gap: 48px; }
    .hiw-step-wrapper { flex-direction: column; }
    .hiw-step { padding: 0; }
    .hiw-divider { display: none; }
  }
</style>
