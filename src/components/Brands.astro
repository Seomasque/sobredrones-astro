---
const brands = [
  { src: "/images/brands/atalmina.png", alt: "Atalmina – Begonias Park", invert: true },
  { src: "/images/brands/kostadelsol.png", alt: "Kosta del Sol Inmobiliaria", invert: false },
  { src: "/images/brands/villarroel.png", alt: "Villarroel – Timeless Architecture", invert: false },
  { src: "/images/brands/atalaya-golf.png", alt: "Atalaya Golf & Country Club", invert: false },
];
---

<section class="brands">
  <p class="brands-heading">Confían en nosotros</p>
  <div class="marquee">
    <div class="marquee-track">
      {[...brands, ...brands].map((b) => (
        <img
          src={b.src}
          alt={b.alt}
          loading="lazy"
          decoding="async"
          class:list={["brand-logo", b.invert && "invert-logo"]}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .brands {
    background-color: #ffffff;
    padding: 48px 0;
    border-top: 1px solid var(--colorBorder);
    border-bottom: 1px solid var(--colorBorder);
    overflow: hidden;
  }
  .brands-heading {
    text-align: center;
    color: var(--colorFont);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    margin: 0 0 32px 0;
  }

  .marquee {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .marquee-track {
    display: inline-flex;
    align-items: center;
    gap: 72px;
    animation: marquee 25s linear infinite;
    white-space: nowrap;
  }

  @keyframes marquee {
    to { transform: translateX(-50%); }
  }

  .brand-logo {
    display: block;
    flex: 0 0 auto;
    height: 70px;
    width: auto;
    max-width: 200px;
    object-fit: contain;
    transition: transform 0.3s ease, filter 0.3s ease;
  }
  .brand-logo:hover {
    transform: scale(1.1);
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
  }
  .brand-logo.invert-logo {
    filter: brightness(0);
    opacity: 0.7;
  }
  .brand-logo.invert-logo:hover {
    filter: brightness(0) drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
    transform: scale(1.1);
  }

  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      gap: 32px 48px;
      white-space: normal;
    }
    .brand-logo:nth-child(n+5) { display: none; }
    .marquee { mask-image: none; -webkit-mask-image: none; }
  }

  @media (max-width: 639px) {
    .brand-logo { height: 55px; max-width: 150px; }
    .marquee-track { gap: 48px; }
  }
</style>
