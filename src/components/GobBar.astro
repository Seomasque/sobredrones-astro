---

<section class="gob-bar">
  <div class="gob-bar-inner">
    <p class="gob-label">Regulado y homologado por</p>
    <div class="gob-logos">
      <div class="gob-logo-card">
        <img src="/images/gob/logo-ministerio-fomento.png" alt="Ministerio de Fomento" class="gob-logo" />
      </div>
      <div class="gob-logo-card">
        <img src="/images/gob/logo-aesa.png" alt="AESA – Agencia Estatal de Seguridad Aérea" class="gob-logo" />
      </div>
      <div class="gob-logo-card">
        <img src="/images/gob/enaire-color.svg" alt="ENAIRE" class="gob-logo" />
      </div>
    </div>
  </div>
</section>

<style>
  .gob-bar {
    background-color: var(--colorNavy);
    padding: 36px 0;
  }
  .gob-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .gob-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 400;
    margin: 0;
  }
  .gob-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }
  .gob-logo-card {
    background: #ffffff;
    border-radius: 6px;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    opacity: 0.9;
  }
  .gob-logo-card:hover { opacity: 1; }
  .gob-logo {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 576px) {
    .gob-logos { gap: 16px; }
    .gob-logo { height: 36px; }
    .gob-logo-card { padding: 10px 14px; }
  }
</style>
