---
// Reseñas reales del Perfil de Empresa de Google de Sobredrones.
const testimonials = [
  {
    name: "Carmen Fraile",
    role: "4 reseñas en Google",
    quote:
      "Excelente y con mucha profesionalidad. Un trato personalizado desde el primer momento hasta el final. Una experiencia muy grata.",
  },
  {
    name: "Carlos Esteban Martínez",
    role: "5 reseñas en Google",
    quote: "Grandes profesionales, quedó un vídeo genial.",
  },
  {
    name: "Christian Thone",
    role: "Local Guide · 25 reseñas en Google",
    quote:
      "Muy contento con los resultados, necesitaba unas tomas y superó mis expectativas! Gran piloto y súper puesto en todo lo relacionado con pilotaje de drones. La Wikipedia de drones!",
  },
  {
    name: "Eduardo Nieto",
    role: "2 reseñas en Google",
    quote: "Excelente profesional, perfecto en ejecución y resultados. Recomendable 120%.",
  },
  {
    name: "SEO masqueseo",
    role: "2 reseñas en Google",
    quote:
      "Buscaba la mejor empresa de drones en Marbella para un vídeo corporativo y el resultado ha sido espectacular. La calidad de la fotografía aérea y los planos en 4K son de otro nivel. Si buscas un piloto de drones profesional que cumpla con toda la normativa y sea puntual, los recomiendo al 100%. ¡Muy buena relación calidad-precio!",
  },
];
---

<section id="testimonios" class="testimonials">
  <div class="container">
    <div class="section-head">
      <h2 class="h-bold">Testimonios</h2>
      <p class="h-light">Lo que dicen nuestros clientes</p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t) => (
        <figure class="testimonial-card">
          <blockquote class="testimonial-quote">&ldquo;{t.quote}&rdquo;</blockquote>
          <div class="testimonial-stars" aria-label="Valoración 5 sobre 5">★★★★★</div>
          <figcaption class="testimonial-author">
            <span class="testimonial-avatar" aria-hidden="true">{t.name.charAt(0)}</span>
            <span>
              <span class="testimonial-name">{t.name}</span>
              <span class="testimonial-role">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials { background-color: #ffffff; padding: 100px 0; }
  .testimonials .container { padding: 0 24px; }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .testimonial-card {
    background-color: var(--colorGrey);
    padding: 40px 30px;
    border-radius: 6px;
    margin: 0;
    transition: box-shadow 0.25s ease-in-out;
  }
  .testimonial-card:hover { box-shadow: 0 12px 28px -14px rgba(29, 53, 87, 0.3); }
  .testimonial-quote {
    font-size: 15px; color: var(--colorFont); font-style: italic;
    line-height: 1.8; margin: 0 0 20px 0;
  }
  .testimonial-stars { color: var(--colorMain); margin-bottom: 16px; font-size: 18px; }
  .testimonial-author { display: flex; align-items: center; }
  .testimonial-avatar {
    display: flex; align-items: center; justify-content: center;
    width: 60px; height: 60px; border-radius: 50%; flex-shrink: 0; margin-right: 16px;
    background: var(--colorMain); color: #fff; font-size: 1.3rem; font-weight: 700;
  }
  .testimonial-name { display: block; font-size: 1rem; font-weight: 700; color: var(--colorDark); }
  .testimonial-role { display: block; font-size: 13px; color: var(--colorFont); }

  @media (max-width: 767px) {
    .testimonials-grid { grid-template-columns: 1fr; }
  }
</style>
